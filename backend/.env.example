PORT=3000
PROJECT_ID=base-maestra-gn
DATASET_ID=agentesIA
TABLE_ID=niss_citas_agente
API_KEY=CAMBIAR_API_KEY
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# PostgreSQL - Railway
# En desarrollo local: usar DATABASE_PUBLIC_URL (switchback.proxy.rlwy.net)
# En producción Railway: usar DATABASE_URL (postgres.railway.internal) — se inyecta automáticamente
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# Orígenes permitidos para CORS (lista separada por comas). Vacío = solo server-to-server.
ALLOWED_ORIGINS=
# Rate limiting (opcionales). Por defecto: 600 peticiones por 60000 ms (1 min).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
